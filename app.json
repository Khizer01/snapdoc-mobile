{
  "expo": {
    "name": "SnapDoc AI",
    "slug": "snapdoc-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "snapdoc",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0F0F14",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapdoc.ai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A5BE8"
      },
      "package": "com.snapdoc.ai",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "SnapDoc needs camera access to scan documents."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F14",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b2d06d42-0cba-4345-84fd-22b685890a3a"
      }
    }
  }
}
